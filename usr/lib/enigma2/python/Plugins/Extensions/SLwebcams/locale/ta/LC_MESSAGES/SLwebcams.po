msgid "Annulla"
msgstr "ரத்து செய்"

msgid "Caricamento webcam..."
msgstr "வெப்கேமரை ஏற்றுகிறது..."

msgid "Categoria non supportata: %s"
msgstr "ஆதரிக்கப்படாத வகை: %s"

msgid "Dimensione buffer (KB)"
msgstr "பரிமாண இடையக (KB)"

msgid "Errore durante il caricamento delle webcam: %s"
msgstr "வெப்கேம்களை ஏற்றுவதில் பிழை: %s"

msgid "Errore durante l'apertura del player: %s"
msgstr "பிளேயரைத் திறப்பதில் பிழை: %s"

msgid "Errore durante la riproduzione a schermo intero: %s"
msgstr "முழுத் திரையில் இயங்குவதில் பிழை: %s"

msgid "Errore durante la riproduzione: %s"
msgstr "விளையாடுவதில் பிழை: %s"

msgid "Errore nel caricamento della categoria: %s"
msgstr "வகையை ஏற்றுவதில் பிழை: %s"

msgid "Errore nel caricamento delle nazioni: %s"
msgstr "நாடுகளை ஏற்றுவதில் பிழை: %s"

msgid "Guarda le webcam da skylinewebcams.com"
msgstr "skylinewebcams.com இலிருந்து வெப்கேம்களைப் பார்க்கவும்"

msgid "Inizializzazione..."
msgstr "துவக்கம்..."

msgid "Live Webcams"
msgstr "நேரடி வெப்கேம்கள்"

msgid "Menu di base caricato"
msgstr "அடிப்படை மெனு ஏற்றப்பட்டது"

msgid "Mostra informazioni"
msgstr "தகவலைக் காட்டு"

msgid "Nessuna webcam disponibile in questa categoria"
msgstr "இந்த வகையில் வெப் கேமராக்கள் எதுவும் இல்லை"

msgid "Salva"
msgstr "சால்வா"

msgid "Seleziona una categoria ({} disponibili)"
msgstr "வகையைத் தேர்ந்தெடுக்கவும் ({} உள்ளது)"

msgid "SkyLine Webcams - %s"
msgstr "ஸ்கைலைன் வெப்கேம்கள் - %s"

msgid "SkyLine Webcams - Impostazioni"
msgstr "ஸ்கைலைன் வெப்கேம்கள் - அமைப்புகள்"

msgid "Stream non disponibile per questa webcam"
msgstr "இந்த வெப்கேமிற்கு ஸ்ட்ரீம் கிடைக்கவில்லை"

msgid "Timeout connessione (sec)"
msgstr "இணைப்பு நேரம் முடிந்தது (வினாடி)"

msgid "Trovate %d nazioni in %s"
msgstr "%s இல் %d நாடுகளைக் கண்டறியவும்"

msgid "Trovate %d webcam"
msgstr "%d வெப்கேமைக் கண்டறியவும்"

msgid "Vista predefinita"
msgstr "இயல்புநிலை பார்வை"

msgid "Web per categoria"
msgstr "வகை வாரியாக வலை"
