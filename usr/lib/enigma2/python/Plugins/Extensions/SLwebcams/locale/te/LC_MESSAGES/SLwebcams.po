msgstr "%d వెబ్‌క్యామ్‌ను కనుగొనండి"

msgid "Vista predefinita"
msgstr "డిఫాల్ట్ వీక్షణ"

msgid "Web per categoria"
msgstr "వర్గం ద్వారా వెబ్"
